# Database & Redis
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/floodrisk
REDIS_URL=redis://localhost:6379/0

# SuprSend Notifications (Get these from your SuprSend dashboard)
SUPRSEND_WORKSPACE_KEY=your_workspace_key_here
SUPRSEND_WORKSPACE_SECRET=your_workspace_secret_here

# App Settings
LOG_LEVEL=info
MODEL_VERSION=latest_model.joblib
